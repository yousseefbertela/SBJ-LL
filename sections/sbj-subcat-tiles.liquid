-%}

{%- if sc_labels != '' -%}
  {%- assign labels = sc_labels | split: '|' -%}
  {%- assign slugs = sc_slugs | split: '|' -%}
  {%- assign imgs = sc_imgs | split: '|' -%}
  <div class="sbj-subcat">
    <ul class="sbj-subcat__row" role="list">
      {%- for label in labels -%}
        <li class="sbj-subcat__tile">
          <a class="sbj-subcat__link" href="/collections/{{ h }}/{{ slugs[forloop.index0] }}">
            <div class="sbj-subcat__media">
              <img class="sbj-subcat__img" src="{{ base }}{{ imgs[forloop.index0] }}?auto=format&q=75&w=400" alt="{{ label | escape }}" loading="lazy">
            </div>
            <span class="sbj-subcat__label">{{ label }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>

  {%- if collection -%}
    <nav class="sbj-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sbj-breadcrumb__sep"> / </span>
      <span>{{ collection.title }}</span>
    </nav>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .sbj-subcat {
    width: 100%;
    margin-inline: auto;
    padding-block: 8px 24px;
    padding-inline: 24px;   /* SKIMS page gutter */
  }
  .sbj-subcat__row {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: none;
    display: flex;
    gap: 12px;              /* SKIMS tile gap */
    overflow-x: auto;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
  }
  .sbj-subcat__row::-webkit-scrollbar { display: none; }
  .sbj-subcat__tile {
    flex: 0 0 160px;        /* SKIMS: fixed small tiles, left-aligned (don't stretch to fill) */
    width: 160px;
    scroll-snap-align: start;
  }
  .sbj-subcat__link { display: block; text-decoration: none; color: var(--color-foreground); }
  .sbj-subcat__media {
    position: relative;
    aspect-ratio: 4 / 5;    /* SKIMS portrait packshot tile */
    overflow: hidden;
    background: #f3f1ee;
  }
  .sbj-subcat__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;      /* SKIMS packshots fill the tile */
    display: block;
    transition: transform 0.5s var(--ease-out-cubic, ease);
  }
  .sbj-subcat__tile:hover .sbj-subcat__img { transform: scale(1.03); }
  .sbj-subcat__label {
    display: block;
    margin-top: 10px;
    text-align: left;       /* SKIMS labels are left-aligned, bold */
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: 14px;
    line-height: 18px;
    letter-spacing: 0.2px;
    text-transform: none;
    color: var(--color-foreground);
  }
  @media (max-width: 749px) {
    .sbj-subcat__tile { flex: 0 0 38%; }
    .sbj-subcat__label { font-size: 12px; }
  }
  .sbj-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 16px 24px 8px;   /* align breadcrumb to the 24px gutter */
    font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #6F6C69;
  }
  .sbj-breadcrumb a {
    color: #6F6C69;
    text-decoration: none;
  }
  .sbj-breadcrumb a:hover { text-decoration: underline; }
  .sbj-breadcrumb__sep { margin: 0 4px; }
{% endstylesheet %}

{% schema %}
{
  "name": "SBJ Subcategory tiles",
  "tag": "section",
  "class": "sbj-subcat-section",
  "settings": [],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Image URL (fallback)" },
        { "type": "text", "id": "label", "label": "Label", "default": "CATEGORY" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{ "name": "SBJ Subcategory tiles" }]
}
{% endschema %}
