{%- comment -%}
  SBJ curated "We think you'd like" carousel — SKIMS match.
  Shows SKIMS white-background FLAT packshots (decoupled from each product's
  model-shot featured image, so the collection grid keeps its model photos)
  while pulling title / fabric / price / link from the REAL product via
  all_products[handle]. Self-contained: CSS + counter/arrow JS below.

  To curate: edit the two parallel arrays (handles + packshot URLs). They must
  stay in the same order — index N of handles pairs with index N of images.
{%- endcomment -%}

{%- assign rec_handles = 'cotton-jersey-t-shirt,smooth-layers-off-the-shoulder-top,cotton-jersey-loose-short,cotton-rib-tank,cupro-jersey-asymmetrical-top,cotton-fleece-double-waistband-short,slinky-knit-cardigan,cotton-jersey-mini-dress' | split: ',' -%}
{%- capture rec_images_raw -%}
https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-AP-TSH-0638-SOT-FLT_337890eb-b813-4d8c-b4fd-b94fb1ae7e59.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-TP-LSL-12347W-COA-FLT.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-SH-SHO-7787W-CBM-FLT.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-AP-TNK-0038-CMB.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-TP-LSL-11920W-PRL-FLT_f82d86f9-b175-4955-9e78-cddf67f722fd.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-BT-SHO-13074W-LHG-FLT.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-TP-LSL-11712W-BFF-FLT.jpg|https://skims.imgix.net/s/files/1/0259/5448/4284/files/SKIMS-LOUNGEWEAR-OP-DRS-12296W-CBM-FLT.jpg
{%- endcapture -%}
{%- assign rec_imgs = rec_images_raw | strip | split: '|' -%}

<section class="sbj-rec" id="sbj-rec-{{ section.id }}">
  <div class="sbj-rec__head">
    <h2 class="sbj-rec__title">{{ section.settings.heading | escape }}</h2>
    <div class="sbj-rec__nav">
      <button type="button" class="sbj-rec__arrow" data-dir="-1" aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 6l-6 6 6 6"/></svg>
      </button>
      <span class="sbj-rec__counter">1 / 1</span>
      <button type="button" class="sbj-rec__arrow" data-dir="1" aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>
  </div>
  <div class="sbj-rec__track">
    {%- for handle in rec_handles -%}
      {%- assign p = all_products[handle] -%}
      {%- assign img = rec_imgs[forloop.index0] -%}
      {%- if p and p.id -%}
        <a class="sbj-rec__card" href="{{ p.url }}">
          <div class="sbj-rec__media">
            <img src="{{ img }}?fm=jpg&w=600" alt="{{ p.title | escape }}" loading="lazy" width="300" height="300">
          </div>
          <div class="sbj-rec__info">
            <span class="sbj-rec__eyebrow">{{ p.type | default: p.vendor }}</span>
            <span class="sbj-rec__name">{{ p.title }}</span>
            <span class="sbj-rec__price">{{ p.price | money }}</span>
            <span class="sbj-rec__heart" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20.6l-1.32-1.2C6 15.16 3 12.45 3 9.13 3 6.42 5.13 4.3 7.85 4.3c1.54 0 3.02.72 3.99 1.85a5.27 5.27 0 0 1 3.99-1.85C18.54 4.3 20.67 6.42 20.67 9.13c0 3.32-3 6.03-7.68 10.27L12 20.6z"/></svg>
            </span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  #sbj-rec-{{ section.id }}.sbj-rec { position: relative; width: 100%; padding: 36px 0 48px; }
  #sbj-rec-{{ section.id }} .sbj-rec__head { position: relative; text-align: center; min-height: 26px; padding: 0 40px; }
  #sbj-rec-{{ section.id }} .sbj-rec__title {
    font-family: var(--font-heading--family); font-weight: 600; font-size: 20px;
    line-height: 24px; letter-spacing: .5px; text-transform: uppercase; margin: 0; color: #2D2A26;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__nav {
    position: absolute; top: 50%; right: 40px; transform: translateY(-50%);
    display: inline-flex; align-items: center; gap: 14px;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__arrow {
    background: none; border: 0; padding: 0; cursor: pointer; width: 22px; height: 22px;
    color: #2D2A26; display: inline-flex; align-items: center; justify-content: center;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__arrow:disabled { opacity: .3; cursor: default; }
  #sbj-rec-{{ section.id }} .sbj-rec__arrow svg { width: 18px; height: 18px; }
  #sbj-rec-{{ section.id }} .sbj-rec__counter {
    font-family: "Inter","Helvetica Neue",Helvetica,Arial,sans-serif; font-size: 13px;
    font-weight: 500; letter-spacing: .3px; color: #2D2A26; min-width: 40px; text-align: center;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__track {
    display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth;
    margin-top: 18px; -ms-overflow-style: none; scrollbar-width: none;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__track::-webkit-scrollbar { display: none; }
  #sbj-rec-{{ section.id }} .sbj-rec__card {
    flex: 0 0 calc(100% / 6); max-width: calc(100% / 6); box-sizing: border-box;
    scroll-snap-align: start; text-decoration: none; color: inherit; position: relative;
    border-left: 1px solid #E8E5DF; border-top: 1px solid #E8E5DF; border-bottom: 1px solid #E8E5DF;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__card:first-child { border-left: none; }
  #sbj-rec-{{ section.id }} .sbj-rec__media { aspect-ratio: 8 / 5; background: #fff; display: block; }
  #sbj-rec-{{ section.id }} .sbj-rec__media img {
    width: 100%; height: 100%; object-fit: contain; padding: 11%; box-sizing: border-box; display: block;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__info {
    position: relative; padding: 12px 44px 6px 24px; display: flex; flex-direction: column; gap: 2px;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__eyebrow {
    font-family: "Inter","Helvetica Neue",Helvetica,Arial,sans-serif; font-size: 10px; font-weight: 500;
    line-height: 14px; letter-spacing: .4px; text-transform: uppercase; color: #6F6C69;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__name {
    font-family: var(--font-heading--family); font-weight: 600; font-size: 14px; line-height: 18px;
    letter-spacing: .35px; text-transform: uppercase; color: #2D2A26;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__price {
    font-family: "Inter","Helvetica Neue",Helvetica,Arial,sans-serif; font-size: 10px; line-height: 14px;
    letter-spacing: .25px; color: #2D2A26; margin-top: 2px;
  }
  #sbj-rec-{{ section.id }} .sbj-rec__heart { position: absolute; right: 24px; top: 12px; width: 18px; height: 18px; color: #2D2A26; }
  #sbj-rec-{{ section.id }} .sbj-rec__heart svg { width: 18px; height: 18px; display: block; }
  @media (max-width: 990px) {
    #sbj-rec-{{ section.id }} .sbj-rec__card { flex-basis: calc(100% / 3); max-width: calc(100% / 3); }
  }
  @media (max-width: 600px) {
    #sbj-rec-{{ section.id }} .sbj-rec__card { flex-basis: calc(100% / 2); max-width: calc(100% / 2); }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('sbj-rec-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('.sbj-rec__track');
    var counter = root.querySelector('.sbj-rec__counter');
    var prev = root.querySelector('[data-dir="-1"]');
    var next = root.querySelector('[data-dir="1"]');
    function pages() { return Math.max(1, Math.ceil(track.scrollWidth / track.clientWidth)); }
    function page() { return Math.min(pages(), Math.round(track.scrollLeft / track.clientWidth) + 1); }
    function render() {
      counter.textContent = page() + ' / ' + pages();
      prev.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
    }
    prev.addEventListener('click', function () { track.scrollBy({ left: -track.clientWidth, behavior: 'smooth' }); });
    next.addEventListener('click', function () { track.scrollBy({ left: track.clientWidth, behavior: 'smooth' }); });
    track.addEventListener('scroll', function () { window.requestAnimationFrame(render); });
    window.addEventListener('resize', render);
    render();
  })();
</script>

{% schema %}
{
  "name": "SBJ Recommend Carousel",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "We think you'd like" }
  ],
  "presets": [ { "name": "SBJ Recommend Carousel" } ]
}
{% endschema %}
