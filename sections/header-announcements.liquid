

{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<aside
  class="announcement-bar spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;"
>
  {%- comment -%} SBJ: logo lives on the announcement row (SKIMS layout). Desktop only; mobile keeps the native header logo. {%- endcomment -%}
  <a href="{{ routes.root_url }}" class="announcement-bar__logo" aria-label="{{ shop.name | escape }}">
    {%- if settings.logo != blank -%}
      <img
        src="{{ settings.logo | image_url: width: 320 }}"
        alt="{{ settings.logo.alt | default: shop.name | escape }}"
        height="24"
        loading="eager"
      >
    {%- else -%}
      <span class="announcement-bar__logo-text">{{ shop.name }}</span>
    {%- endif -%}
  </a>

  {% liquid
    assign autoplay = false
    assign show_arrows = false
    if section.blocks.size > 1
      assign autoplay = true
      assign show_arrows = true
    endif
  %}

  <announcement-bar-component
    class="announcement-bar__slider"
    {% if autoplay == true %}
      autoplay="{{ section.settings.speed }}" aria-live="polite"
    {% endif %}
  >
    {% if show_arrows %}
      {% render 'slideshow-arrows', icon_style: 'chevron' %}
    {% endif %}

    <div class="announcement-bar__slides">
      {% content_for 'blocks' %}
    </div>
  </announcement-bar-component>
</aside>

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    position: relative;
  }

  /* SBJ: logo on the announcement row (SKIMS 2-row header). Hidden on mobile. */
  .announcement-bar__logo {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .announcement-bar__logo {
      position: absolute;
      inset-inline-start: 22px;
      top: 50%;
      transform: translateY(-50%);
      display: inline-flex;
      align-items: center;
      z-index: 3;
      text-decoration: none;
      line-height: 1;
    }

    .announcement-bar__logo-text {
      font-family: var(--font-heading--family);
      font-weight: 800;
      font-size: 2.5rem;
      line-height: 1;
      letter-spacing: 0.04em;
      color: var(--color-foreground);
      white-space: nowrap;
    }

    .announcement-bar__logo img {
      display: block;
      height: 44px !important;
      width: auto !important;
      max-width: none !important;
      max-height: none !important;
    }

    /* Logo now lives on the announcement row, so hide the one in the nav row on desktop */
    .header-section .header-logo {
      display: none !important;
    }

    /* SBJ: header + announcement span near full-width like SKIMS (override narrow page-width centering) */
    .header-section .header__columns {
      max-width: none !important;
      margin-inline: 0 !important;
      padding-inline: 32px !important;
    }

    .announcement-bar {
      max-width: none !important;
      margin-inline: 0 !important;
      padding-inline: 0 !important;
    }

    /* Right-side icons: thinner stroke + even, slightly tighter spacing (SKIMS-style) */
    .header-section {
      --icon-stroke-width: 1px;
    }

    /* Even spacing + vertical centering; remove the negative margin that overlapped search & account */
    .header-section .header__column--right {
      gap: 8px !important;
      align-items: center !important;
    }

    .header-section .header__column--right header-actions {
      margin-inline-start: 0 !important;
      gap: 8px !important;
      align-items: center !important;
    }

    /* Uniform 34px footprint for every icon so they're evenly spaced and aligned */
    .header-section .header__column--right .header-actions__action,
    .header-section .header__column--right .account-button,
    .header-section .header__column--right .search-action,
    .header-section .header__column--right .header-actions__wishlist {
      width: 34px !important;
      min-width: 34px !important;
      height: 34px !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    .header-section .header__column--right .account-button shopify-account {
      min-width: 34px !important;
      height: 34px !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
    }

    .header-section .header__column--right .svg-wrapper {
      width: 34px !important;
      height: 34px !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
    }

    /* TRANSPARENT HERO STATE (homepage, at top): announcement text + logo go white over the hero */
    body:has(#header-component[transparent][data-sticky-state='inactive']) .announcement-bar p,
    body:has(#header-component[transparent][data-sticky-state='inactive']) .announcement-bar__text,
    body:has(#header-component[transparent][data-sticky-state='inactive']) .announcement-bar__logo-text {
      color: #ffffff !important;
    }

    body:has(#header-component[transparent][data-sticky-state='inactive']) .announcement-bar__logo img {
      filter: brightness(0) invert(1);
    }

    body:has(#header-component[transparent][data-sticky-state='inactive']) .announcement-bar {
      --border-bottom-width: 0px;
    }

    /* Logo appears in the nav row once the header sticks on scroll */
    #header-component[data-sticky-state='active'] .header-logo {
      display: flex !important;
    }

    /* Readability scrim behind the transparent header; disappears once scrolled (white bar takes over) */
    body:has(#header-component[transparent][data-sticky-state='inactive'])::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 130px;
      background: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
      z-index: 4;
      pointer-events: none;
    }
  }

  .announcement-bar__slider {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: calc(100% - var(--button-size) * 2);
    max-width: 680px;
    margin-inline: auto;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;

    &[aria-hidden='true'] {
      opacity: 0;
      visibility: hidden;
    }
  }

  .announcement-bar__slider slideshow-arrows {
    padding: 0;
    mix-blend-mode: normal;
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--color-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    padding: 0;
    width: var(--button-size);
    height: var(--button-size);
    align-items: center;
    justify-content: center;
    opacity: 1;
    animation: none;

    @media screen and (min-width: 750px) {
      --slideshow-control-offset: calc((var(--button-size) - var(--icon-size-xs)) / 2);

      .section--page-width &.slideshow-control--previous {
        transform: translateX(var(--slideshow-control-offset));
      }
    }
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .announcement-bar__slide {
    place-content: center;
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "t:settings.color_scheme"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
