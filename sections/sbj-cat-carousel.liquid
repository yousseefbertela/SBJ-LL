{%- comment -%}
  SBJ Category carousel — SKIMS-style portrait category cards in a horizontal,
  scroll-snapping carousel (not a static grid). Each card: image + label below,
  links to a collection. Bespoke because Horizon's native collection-list did not
  resolve collection images in carousel mode. Images are editor-overridable
  (image_picker) with a theme-asset fallback.
{%- endcomment -%}

<div class="sbj-catcar-wrap">
  <ul class="sbj-catcar" role="list">
    {%- for block in section.blocks -%}
      <li class="sbj-catcar__card" {{ block.shopify_attributes }}>
        <a class="sbj-catcar__link" href="{{ block.settings.link | default: '#' }}">
          <div class="sbj-catcar__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image
                | image_url: width: 800
                | image_tag: loading: 'lazy', class: 'sbj-catcar__img',
                  widths: '300, 450, 600, 800', alt: block.settings.label }}
            {%- elsif block.settings.image_asset != blank -%}
              <img class="sbj-catcar__img" src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'sbj-catcar__img' }}
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <span class="sbj-catcar__label">{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      </li>
    {%- endfor -%}
  </ul>
</div>

{% stylesheet %}
  .sbj-catcar-wrap { width: 100%; }
  .sbj-catcar {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .sbj-catcar::-webkit-scrollbar { display: none; }
  .sbj-catcar__card {
    flex: 0 0 auto;
    width: calc((100% - 72px) / 4);
    scroll-snap-align: start;
  }
  .sbj-catcar__link { display: block; text-decoration: none; color: var(--color-foreground); }
  .sbj-catcar__media {
    position: relative;
    aspect-ratio: 600 / 750;
    overflow: hidden;
    background: #f3f3f3;
  }
  .sbj-catcar__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sbj-catcar__label {
    display: block;
    margin-top: 12px;
    text-align: center;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 700);
    font-size: 16px;
    line-height: 20px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--color-foreground);
  }
  @media (max-width: 749px) {
    .sbj-catcar__card { width: 62vw; }
    .sbj-catcar { gap: 12px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SBJ Category carousel",
  "tag": "section",
  "class": "sbj-catcar-section",
  "settings": [],
  "blocks": [
    {
      "type": "cat",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_asset", "label": "Fallback image (theme asset filename)" },
        { "type": "text", "id": "label", "label": "Label", "default": "CATEGORY" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "SBJ Category carousel",
      "blocks": [
        { "type": "cat", "settings": { "label": "BRAS", "image_asset": "cat-bras.jpg" } },
        { "type": "cat", "settings": { "label": "SLEEP", "image_asset": "cat-sleep.jpg" } },
        { "type": "cat", "settings": { "label": "SHAPEWEAR", "image_asset": "cat-shapewear.jpg" } },
        { "type": "cat", "settings": { "label": "BEST SELLERS", "image_asset": "cat-best.jpg" } }
      ]
    }
  ]
}
{% endschema %}
