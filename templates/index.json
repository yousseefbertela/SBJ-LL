{
  "sections": {
    "sbj_css": {
      "type": "custom-liquid",
      "name": "SKIMS homepage CSS",
      "settings": {
        "custom_liquid": "<span id=\"sbj-home\" hidden aria-hidden=\"true\" style=\"display:none\"></span>\n<script>document.body.classList.add('sbj-home');</script>\n<style>\n/* ============================================================\n   SKIMS-match homepage CSS - Horizon (native-first).\n   SCOPE: HOMEPAGE ONLY. Every rule is nested under\n   body:has(#sbj-home) with a body.sbj-home JS fallback for\n   browsers without :has(). The #sbj-home marker + class are\n   injected ONLY by this custom-liquid section, which lives\n   ONLY in templates/index.json -> zero global side effects.\n   Covers ONLY what native section settings cannot.\n   ============================================================ */\n\n/* Scoped tokens (no :root leakage) */\nbody:has(#sbj-home), body.sbj-home {\n  --sbj-overlay-text: #F6F6F6;\n  --sbj-ink: #2D2A26;\n  --sbj-cta: #F6F6F6;\n  --sbj-spacer: 16px;\n  --sbj-grid-gap: 24px;\n  --sbj-font-ui: \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n}\n\n/* 1. \"Shop Now\" CTA - underlined bold text, no button box (on dark media) */\nbody:has(#sbj-home) .hero .button,\nbody:has(#sbj-home) .hero .button-secondary,\nbody:has(#sbj-home) .hero .link,\nbody.sbj-home .hero .button,\nbody.sbj-home .hero .button-secondary,\nbody.sbj-home .hero .link {\n  display: inline-block;\n  background: none !important;\n  border: 0 !important;\n  box-shadow: none !important;\n  border-radius: 0 !important;\n  padding: 0 !important;\n  min-height: 0 !important;\n  font-family: var(--sbj-font-ui) !important;\n  font-size: 14px !important;\n  font-weight: 700 !important;\n  line-height: 20px !important;\n  letter-spacing: normal !important;\n  text-transform: none !important;\n  color: var(--sbj-cta) !important;\n  text-decoration: underline !important;\n  text-decoration-color: currentColor !important;\n  text-underline-offset: 2px;\n  width: auto !important;\n}\nbody:has(#sbj-home) .hero .button:hover,\nbody:has(#sbj-home) .hero .button-secondary:hover,\nbody:has(#sbj-home) .hero .link:hover,\nbody.sbj-home .hero .button:hover,\nbody.sbj-home .hero .button-secondary:hover,\nbody.sbj-home .hero .link:hover {\n  color: var(--sbj-cta) !important;\n  opacity: .85;\n  text-decoration: underline !important;\n  text-decoration-color: currentColor !important;\n}\n\n/* 2. Overlay heading/subhead - #F6F6F6, bottom-left anchored, ~24px inset */\nbody:has(#sbj-home) .hero .hero__content-wrapper,\nbody.sbj-home .hero .hero__content-wrapper {\n  justify-content: flex-end;\n  align-items: flex-start;\n  text-align: left;\n  padding: 24px;\n}\nbody:has(#sbj-home) .hero .hero__content-wrapper,\nbody:has(#sbj-home) .hero .hero__content-wrapper .group-block-content,\nbody:has(#sbj-home) .hero .hero__content-wrapper :is(h1,h2,h3,h4,h5,h6,p,span),\nbody.sbj-home .hero .hero__content-wrapper,\nbody.sbj-home .hero .hero__content-wrapper .group-block-content,\nbody.sbj-home .hero .hero__content-wrapper :is(h1,h2,h3,h4,h5,h6,p,span) {\n  color: var(--sbj-overlay-text) !important;\n  text-align: left;\n}\nbody:has(#sbj-home) .hero .hero__content-wrapper .group-block-content,\nbody.sbj-home .hero .hero__content-wrapper .group-block-content {\n  align-items: flex-start;\n}\n\n/* 3. Zero-gutter full-bleed rhythm - edge-to-edge banners, ~16px band gaps */\nbody:has(#sbj-home) .hero,\nbody:has(#sbj-home) .hero .hero__container,\nbody.sbj-home .hero,\nbody.sbj-home .hero .hero__container {\n  padding-inline: 0 !important;\n  margin-inline: 0 !important;\n  max-width: 100% !important;\n}\nbody:has(#sbj-home) .hero .hero__media,\nbody.sbj-home .hero .hero__media {\n  width: 100%;\n  object-fit: cover;\n}\nbody:has(#sbj-home) .shopify-section:has(> .hero),\nbody.sbj-home .shopify-section:has(> .hero) {\n  margin-block: 0;\n}\nbody:has(#sbj-home) .shopify-section:has(> .hero) + .shopify-section,\nbody.sbj-home .shopify-section:has(> .hero) + .shopify-section {\n  margin-top: var(--sbj-spacer);\n}\n\n/* 4. Brand statement - centered 36/48, #2D2A26, ls .9px, generous padding.\n   Add class \"sbj-brand-statement\" to the final text/rich-text band. */\nbody:has(#sbj-home) .sbj-brand-statement,\nbody.sbj-home .sbj-brand-statement {\n  text-align: center;\n  padding-block: 48px;\n  padding-inline: 24px;\n}\nbody:has(#sbj-home) .sbj-brand-statement :is(h1,h2,h3,h4,p),\nbody.sbj-home .sbj-brand-statement :is(h1,h2,h3,h4,p) {\n  font-size: 36px;\n  line-height: 48px;\n  letter-spacing: .9px;\n  color: var(--sbj-ink);\n  text-align: center;\n  margin: 0;\n}\n\n/* 5. Category 4-up - 4 cols, gap 24px, labels beneath, full-bleed.\n   Add class \"sbj-cat-4up\" to the grid wrapper. */\nbody:has(#sbj-home) .sbj-cat-4up,\nbody.sbj-home .sbj-cat-4up {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: var(--sbj-grid-gap);\n  padding-inline: 0;\n  margin-inline: 0;\n  max-width: 100%;\n}\nbody:has(#sbj-home) .sbj-cat-4up figcaption,\nbody:has(#sbj-home) .sbj-cat-4up .sbj-cat-label,\nbody.sbj-home .sbj-cat-4up figcaption,\nbody.sbj-home .sbj-cat-4up .sbj-cat-label {\n  margin-top: 12px;\n  font-family: var(--sbj-font-ui);\n  font-size: 14px;\n  font-weight: 700;\n  line-height: 20px;\n  color: var(--sbj-ink);\n  text-align: left;\n}\n@media (max-width: 749px) {\n  body:has(#sbj-home) .sbj-cat-4up,\n  body.sbj-home .sbj-cat-4up {\n    grid-template-columns: repeat(2, 1fr);\n    gap: 12px;\n  }\n}\n</style>",
        "color_scheme": "scheme-1",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
