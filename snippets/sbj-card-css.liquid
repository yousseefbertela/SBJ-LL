{%- comment -%}
  SBJ / SKIMS-match PRODUCT CARDS + PRODUCT PAGE.
  Loaded globally from layout/theme.liquid; rules are scoped to collection and
  product templates (via the data-template on #MainContent) so the homepage
  trending keeps its own rules in sbj-home-css. Pairs with the eyebrow + badge
  custom-liquid blocks in templates/collection*.json and product.json.
{%- endcomment -%}
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');
/* SKIMS title font — free "T-Star Pro Headline" lookalike (Space Grotesk).
   Overrides the heading family site-wide; eyebrow/price stay Inter like SKIMS. */
:root, body {
  --font-heading--family: "Space Grotesk", "Archivo", system-ui, sans-serif !important;
}

/* SKIMS product cards have no quick-add button — just the wishlist heart.
   Hide Horizon's quick-add overlay on every product card (all pages). */
.product-card .quick-add,
.product-card quick-add-component,
.product-card .quick-add-modal,
.product-card [class*="quick-add"] {
  display: none !important;
}

/* Eyebrow — product type / fabric family, muted grey uppercase (SKIMS) */
:is([data-template^="collection"], [data-template^="product"]) .sbj-eyebrow {
  display: block;
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 10px;
  font-weight: 500;
  line-height: 14px;
  letter-spacing: 0.25px;
  text-transform: uppercase;
  color: #6F6C69;
  margin: 10px 0 0;
}

/* Product name — clean regular-weight uppercase (SKIMS card name line is 14px/400).
   The title renders as a .text-block div whose weight comes from --font-weight
   (= --font-heading--weight, ~900); override the variable, not just font-weight. */
:is([data-template^="collection"], [data-template^="product"]) .product-card__content .user-select-text,
:is([data-template^="collection"], [data-template^="product"]) .product-card__content [class*="product_title"] {
  --font-weight: 400 !important;
  font-family: var(--font-heading--family) !important;
  font-weight: 400 !important;
  font-size: 14px !important;
  line-height: 18px !important;
  letter-spacing: 0.35px !important;
  text-transform: uppercase !important;
  color: #2D2A26 !important;
}

/* Card price — Inter, small */
:is([data-template^="collection"], [data-template^="product"]) .product-card__content .price {
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 11px !important;
  line-height: 14px !important;
  letter-spacing: 0.25px !important;
  color: #2D2A26 !important;
}

/* Badge wrapper: zero-height positioned div placed right after the gallery in DOM.
   bottom: Xpx on the badge is measured from the wrapper's top edge, which sits exactly
   at the bottom of the gallery — so the badge floats inside the image at bottom-left. */
:is([data-template^="collection"]) .sbj-badge-pos {
  position: relative;
  height: 0;
  overflow: visible;
  z-index: 2;
}
/* Best Seller / New badge — small dark label, bottom-left over the image (SKIMS position) */
:is([data-template^="collection"], [data-template^="product"]) .sbj-badge {
  position: absolute;
  bottom: 10px;
  left: 10px;
  z-index: 2;
  background: #2D2A26;
  color: #fff;
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 10px;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0.2px;
  padding: 6px 8px;
}

/* Swatches row — color circles left, heart right (SKIMS layout) */
:is([data-template^="collection"]) .sbj-swatches-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8px 0 0;
  min-height: 22px;
  padding-right: 16px;   /* pull the wishlist heart in from the card edge (SKIMS) */
}
:is([data-template^="collection"]) .sbj-swatches {
  display: flex;
  gap: 4px;
  flex-wrap: nowrap;
  overflow: hidden;
  max-width: calc(100% - 28px);
}
:is([data-template^="collection"]) .sbj-swatch {
  width: 14px;
  height: 14px;
  border-radius: 2px;
  border: 1px solid rgba(0,0,0,0.12);
  display: inline-block;
  flex-shrink: 0;
  background: #ccc;
  box-sizing: border-box;
}
/* First (active) swatch gets the SKIMS selection ring */
:is([data-template^="collection"]) .sbj-swatch:first-child {
  outline: 1px solid #2D2A26;
  outline-offset: 1px;
}
:is([data-template^="collection"]) .sbj-swatch--black { background: #1a1a1a; }
:is([data-template^="collection"]) .sbj-swatch--white { background: #fff; border-color: rgba(0,0,0,0.3); }
:is([data-template^="collection"]) .sbj-swatch--sand { background: #c2a98a; }
:is([data-template^="collection"]) .sbj-swatch--pink { background: #f5a8be; }
:is([data-template^="collection"]) .sbj-swatch--beige { background: #e0cdb8; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--grey,
:is([data-template^="collection"]) .sbj-swatch--gray { background: #9a9a9a; }
:is([data-template^="collection"]) .sbj-swatch--heather-grey { background: #b4b4b4; }
:is([data-template^="collection"]) .sbj-swatch--navy { background: #1a2a5a; }
:is([data-template^="collection"]) .sbj-swatch--brown { background: #5c3d2e; }
:is([data-template^="collection"]) .sbj-swatch--dark-brown { background: #3d1f0f; }
:is([data-template^="collection"]) .sbj-swatch--oatmeal { background: #ddd4c4; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--mauve { background: #c4a0b0; }
:is([data-template^="collection"]) .sbj-swatch--cocoa { background: #5c3a28; }
:is([data-template^="collection"]) .sbj-swatch--onyx { background: #2a2a2a; }
:is([data-template^="collection"]) .sbj-swatch--marble { background: #d0c8c0; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--mineral-blue { background: #5a7a8a; }
:is([data-template^="collection"]) .sbj-swatch--slate { background: #607a8a; }
/* Extended SKIMS palette (catalog colors) */
:is([data-template^="collection"]) .sbj-swatch--clay { background: #cdab92; }
:is([data-template^="collection"]) .sbj-swatch--clay-heather { background: #c2a994; }
:is([data-template^="collection"]) .sbj-swatch--sienna { background: #9e6b52; }
:is([data-template^="collection"]) .sbj-swatch--sienna-heather { background: #ab7d68; }
:is([data-template^="collection"]) .sbj-swatch--cocoa-heather { background: #6f4d3c; }
:is([data-template^="collection"]) .sbj-swatch--mineral { background: #6c8893; }
:is([data-template^="collection"]) .sbj-swatch--bronze { background: #8a6a3f; }
:is([data-template^="collection"]) .sbj-swatch--snow { background: #f6f4f0; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--chalk { background: #ece7df; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--paper { background: #e9e3d6; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--oyster { background: #d7cfc2; border-color: rgba(0,0,0,0.2); }
:is([data-template^="collection"]) .sbj-swatch--peony { background: #e7a3b3; }
:is([data-template^="collection"]) .sbj-swatch--bubble-gum { background: #f4a6c0; }
:is([data-template^="collection"]) .sbj-swatch--cherry-blossom { background: #f1cdd8; }
:is([data-template^="collection"]) .sbj-swatch--lilac { background: #c7b6d9; }
:is([data-template^="collection"]) .sbj-swatch--poppy { background: #d6492f; }
:is([data-template^="collection"]) .sbj-swatch--phoenix { background: #c0473a; }
:is([data-template^="collection"]) .sbj-swatch--espresso { background: #3a2a22; }
:is([data-template^="collection"]) .sbj-swatch--umber-leopard { background: #7c5c3c; }
:is([data-template^="collection"]) .sbj-swatch--kyanite { background: #38597a; }
:is([data-template^="collection"]) .sbj-swatch--ivy { background: #495a39; }
:is([data-template^="collection"]) .sbj-swatch--cumin { background: #b08842; }
:is([data-template^="collection"]) .sbj-swatch--poppy { background: #d6492f; }
:is([data-template^="collection"]) .sbj-swatch--chalk { background: #ece7df; border-color: rgba(0,0,0,0.2); }
/* Heart button in swatches row */
:is([data-template^="collection"]) .sbj-heart {
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  color: #2D2A26;
  line-height: 1;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
:is([data-template^="collection"]) .sbj-heart svg {
  width: 18px;
  height: 18px;
  display: block;
}

/* Force exactly 4 product columns on collection pages (SKIMS is 4-col) */
@media screen and (min-width: 750px) {
  [data-template^="collection"] .product-grid {
    --product-grid-columns-desktop: repeat(4, 1fr) !important;
  }
}

/* Taller card image to match SKIMS (~2:3 / 0.69, taller than Horizon's 4:5 portrait).
   Scoped to the MAIN product grid so the "We think you'd like" carousel keeps its own ratio. */
#MainContent[data-template^="collection"] .product-grid .card-gallery {
  --gallery-aspect-ratio: 0.69 !important;
}

/* ===== SKIMS page gutter — 24px each side on the collection content ===== */
/* SKIMS wraps heading + tiles + filters + grid in a full-width container with a
   flat 24px inline padding (no max-width). Match that. The "We think you'd like"
   carousel deliberately stays full-bleed (its own section). */

/* Filter bar: align to the 24px gutter (span all columns, drop the inset). */
#MainContent[data-template^="collection"] .facets-block-wrapper {
  grid-column: 1 / -1 !important;
  margin-inline: 0 !important;
  padding-inline: 24px !important;
  max-width: none !important;
}
/* Product grid: 24px gutter (was full-bleed). */
#MainContent[data-template^="collection"] .product-grid {
  padding-inline: 24px !important;
}
/* Collection heading: section is now full-width (template) — pad its content to the
   flat 24px gutter so the title/description align with the tiles + grid (SKIMS). */
#MainContent[data-template^="collection"] [id*="__section"] .custom-section-content {
  max-width: none !important;
  width: 100% !important;
  margin-inline: 0 !important;
  padding-inline: 24px !important;
}

/* Collection title — SKIMS "CLOTHING": 30px heavy uppercase (was ~48px). */
#MainContent[data-template^="collection"] h1 {
  font-family: var(--font-heading--family) !important;
  font-size: 30px !important;
  font-weight: 800 !important;
  line-height: 1.1 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.75px !important;
}

/* ----- Product page (PDP) — SKIMS match ------------------------------------ */
/* Eyebrow (fabric) — bold dark uppercase, sits above the name (SKIMS).
   Scoped with [data-template] so it beats the general .sbj-eyebrow rule. */
[data-template^="product"] .sbj-eyebrow--pdp {
  display: inline-block;
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  line-height: 16px !important;
  letter-spacing: 0.2px !important;
  text-transform: uppercase !important;
  color: #2D2A26 !important;
  margin: 0 0 -6px !important;
  text-decoration: underline !important;
  text-decoration-thickness: 1px !important;
  text-underline-offset: 4px !important;
}
/* PDP name — heavy uppercase, 26px / 700 (SKIMS "MINI DRESS") */
[data-template^="product"] .product-details h1,
[data-template^="product"] .product-details h1 * {
  font-family: var(--font-heading--family) !important;
  font-weight: 700 !important;
  font-size: 26px !important;
  line-height: 1.1 !important;
  letter-spacing: 0.3px !important;
  text-transform: uppercase !important;
  color: #1A1A1A !important;
  margin: 0 !important;
}
/* PDP price — Inter, 16px medium */
[data-template^="product"] .product-details .price {
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  letter-spacing: 0.2px !important;
  color: #2D2A26 !important;
}
/* Tight stacked header (eyebrow/name/price) */
[data-template^="product"] .product-details .group-block-content { gap: 6px !important; }

/* Variant legends — small title-case label (SKIMS "Size" / color name) */
[data-template^="product"] .product-details .variant-option legend {
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  letter-spacing: 0.2px !important;
  text-transform: none !important;
  color: #2D2A26 !important;
  margin-bottom: 8px !important;
}
/* Size legend → "Size" + selected value grouped left, "Size Guide" pushed right (SKIMS "Size  M ... Size Guide") */
[data-template^="product"] fieldset[data-option-id$="size"] legend {
  display: flex !important;
  align-items: baseline !important;
  justify-content: flex-start !important;
  gap: 8px !important;
  width: 100% !important;
}
/* selected size value beside the label (SKIMS shows it bold/dark next to "Size") */
[data-template^="product"] .sbj-size-name {
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  letter-spacing: 0.2px !important;
  text-transform: uppercase !important;
  color: #1A1A1A !important;
}
[data-template^="product"] .sbj-size-guide {
  margin-left: auto !important;
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 12px !important;
  font-weight: 400 !important;
  letter-spacing: 0.2px !important;
  text-transform: none !important;
  color: #6F6C69 !important;
  text-decoration: underline !important;
  text-underline-offset: 3px !important;
  cursor: pointer;
  background: none;
  border: 0;
  padding: 0;
}
/* Color legend → shows the selected color name (SKIMS "Cherry Blossom"), semibold dark */
[data-template^="product"] fieldset[data-option-id$="color"] legend {
  font-size: 14px !important;
  font-weight: 600 !important;
  letter-spacing: 0.2px !important;
  color: #1A1A1A !important;
  margin-bottom: 12px !important;
}
[data-template^="product"] fieldset[data-option-id$="color"] legend .sbj-color-name {
  font-weight: 600 !important;
}
/* Color swatch row → wider gaps like SKIMS + extra breathing room before "Size" */
[data-template^="product"] fieldset[data-option-id$="color"] { gap: 12px !important; margin-bottom: 30px !important; }
/* Tight flex row of option buttons (override Horizon's equal-width grid) */
[data-template^="product"] .product-details .variant-option {
  margin-bottom: 18px !important;
  display: flex !important;
  flex-wrap: wrap !important;
  gap: 8px !important;
  align-items: center !important;
}
[data-template^="product"] .product-details .variant-option legend { flex: 0 0 100% !important; }
/* Don't let Horizon's equal-width buttons stretch — keep swatches/boxes their own size */
[data-template^="product"] .product-details .variant-option__button-label { margin: 0 !important; flex: 0 0 auto !important; }
/* Hide quantity stepper + express checkout so the CTA is full-width (SKIMS) */
[data-template^="product"] .product-details .quantity-selector-wrapper,
[data-template^="product"] .product-details .accelerated-checkout-block { display: none !important; }

/* SIZE → bordered boxes that fill the row evenly (SKIMS) */
[data-template^="product"] fieldset[data-option-id$="size"] {
  gap: 8px !important;
}
[data-template^="product"] fieldset[data-option-id$="size"] .variant-option__button-label {
  flex: 1 1 0 !important;
  min-width: 48px !important;
  max-width: 110px !important;
  height: 48px !important;
  padding: 0 8px !important;
  border: 1px solid rgba(0,0,0,0.18) !important;
  border-radius: 0 !important;
  background: #fff !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-size: 13px !important;
  letter-spacing: 0.3px !important;
  color: #2D2A26 !important;
  cursor: pointer;
  transition: border-color .15s, background .15s, color .15s;
}
[data-template^="product"] fieldset[data-option-id$="size"] .variant-option__button-label__pill { display: none !important; }
[data-template^="product"] fieldset[data-option-id$="size"] .variant-option__button-label:hover { border-color: #2D2A26 !important; }
[data-template^="product"] fieldset[data-option-id$="size"] .variant-option__button-label:has(input:checked) {
  border-color: #2D2A26 !important;
  background: #2D2A26 !important;
  color: #fff !important;
}
[data-template^="product"] fieldset[data-option-id$="size"] .variant-option__button-label:has(input[data-option-available="false"]) {
  color: #b3b0ac !important;
  border-color: rgba(0,0,0,0.10) !important;
}

/* COLOR → square color swatches (the LABEL itself is the swatch; Horizon's
   pill + ::before are neutralized so nothing overlays the color). */
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label {
  position: relative !important;
  padding: 0 !important;
  margin: 0 !important;
  width: 30px !important;
  min-width: 30px !important;
  max-width: 30px !important;
  height: 30px !important;
  min-height: 30px !important;
  max-height: 30px !important;
  border-radius: 6px !important;
  border: 1px solid rgba(0,0,0,0.12) !important;
  background: #ccc;
  overflow: hidden !important;
  display: inline-block !important;
  box-sizing: border-box !important;
  line-height: 0 !important;
  cursor: pointer;
}
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label::before,
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label::after { content: none !important; display: none !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label__pill,
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label__text { display: none !important; }
/* Suppress default focus ring (selection shown by the checked ring/fill) */
[data-template^="product"] .product-details .variant-option__button-label,
[data-template^="product"] .product-details .variant-option__button-label:focus,
[data-template^="product"] .product-details .variant-option__button-label:focus-within,
[data-template^="product"] .product-details .variant-option__button-label input {
  outline: none !important;
  box-shadow: none !important;
}
/* Checked swatch → SKIMS selection ring */
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input:checked) {
  outline: 1px solid #2D2A26 !important;
  outline-offset: 2px !important;
}
/* Color name → hex on the label (matches card palette; case-insensitive) */
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="black" i]) { background:#1a1a1a !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="onyx" i]) { background:#2a2a2a !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="white" i]) { background:#fff !important; border-color:rgba(0,0,0,0.3) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="snow" i]) { background:#f6f4f0 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="chalk" i]) { background:#ece7df !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="paper" i]) { background:#e9e3d6 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="oyster" i]) { background:#d7cfc2 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="bone" i]) { background:#ece5d8 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="sand" i]) { background:#c2a98a !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="beige" i]) { background:#e0cdb8 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="oatmeal" i]) { background:#ddd4c4 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="marble" i]) { background:#d0c8c0 !important; border-color:rgba(0,0,0,0.2) !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="pink" i]) { background:#f5a8be !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="peony" i]) { background:#e7a3b3 !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="bubble gum" i]) { background:#f4a6c0 !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="cherry blossom" i]) { background:#f1cdd8 !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="lilac" i]) { background:#c7b6d9 !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="mauve" i]) { background:#c4a0b0 !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="navy" i]) { background:#1a2a5a !important; }
[data-template^="product"] fieldset[data-option-id$="color"] .variant-option__button-label:has(input[value="kyanite" i]) { background:#38597a !important; }
