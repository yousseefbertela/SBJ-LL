<style>
{%- comment -%} SKIMS' bold type is Tstar Pro Headline @400 (a medium look). Our heading
   font ships only Archivo 900, so load a medium Archivo weight to match (global = footer
   renders on every page, so the home category labels + brand statement can use it too). {%- endcomment -%}
{{ settings.type_heading_font | font_modify: 'weight', '500' | font_face: font_display: 'swap' }}

/* === SBJ Footer — SKIMS-match styles, all pages === */

/* 1. Three-column layout: narrow | wide | narrow (HELP | Newsletter | MORE)
   4 total blocks in the grid (3 groups + social). The 4th item wraps to its own row. */
@media screen and (min-width: 990px) {
  .footer-content {
    grid-template-columns: 1fr 2fr 1fr !important;
    align-items: start;
  }
  /* Social block (4th child) wraps to second row and spans all 3 columns, centered */
  .footer-content > *:nth-child(4) {
    grid-column: 1 / -1;
    display: flex !important;
    justify-content: center !important;
    padding-top: 36px;
  }
}

/* 2. HELP / MORE column headings (h3 inside group text blocks).
   SKIMS: 16px / heavy / lh20 / ls0.4 / uppercase / centered. !important so the
   editor block's inline text settings can't override the SKIMS match. */
.footer-content h3 {
  margin: 0 0 18px;
  font-family: var(--font-heading--family) !important;
  font-weight: 500 !important; /* SKIMS Tstar Pro Headline @400 reads medium, not black */
  font-size: 16px !important;
  line-height: 20px !important;
  letter-spacing: 0.4px !important;
  text-transform: uppercase !important;
  text-align: center !important;
  color: var(--color-foreground) !important;
}

/* 3. Footer link lists — target ul/li inside footer groups (no class allowed by Shopify) */
.footer-content ul {
  list-style: none;
  margin: 0;
  padding: 0;
  text-align: center;
}
.footer-content ul li { margin: 0; }
.footer-content ul li a {
  display: inline-block;
  font-family: "Inter", sans-serif !important;
  font-size: 12px !important;
  font-weight: 400 !important;
  line-height: 28px !important;
  letter-spacing: normal !important;
  text-transform: none !important;
  color: var(--color-foreground) !important;
  text-decoration: none;
}
.footer-content ul li a:hover { text-decoration: underline; }

/* 4. Newsletter heading (h2) "STAY IN THE KNOW" — SKIMS: 24px / lh30 / ls0.6 /
   heavy / uppercase / centered. !important because the editor text block sets an
   inline font-size (was rendering 32px) that otherwise wins over this rule. */
.footer-content h2 {
  margin: 0 0 12px !important;
  font-family: var(--font-heading--family) !important;
  font-weight: 500 !important; /* SKIMS "STAY IN THE KNOW" = Tstar Headline @400, medium */
  font-size: 24px !important;
  line-height: 30px !important;
  letter-spacing: 0.6px !important;
  text-transform: uppercase !important;
  text-align: center !important;
  color: var(--color-foreground) !important;
}

/* 5. Newsletter subtext paragraph */
.footer-content .group-block-content p {
  font-size: 13px;
  line-height: 1.6;
  text-align: center;
  margin: 0 auto 4px;
  max-width: 360px;
  color: var(--color-foreground);
}

/* 6. Email signup: sharp rectangular border (match SKIMS, no pill) */
.footer-content .email-signup {
  width: 100%;
  max-width: 400px;
  margin-inline: auto;
}

/* 7. Mobile: center everything */
@media screen and (max-width: 989px) {
  .footer-content { text-align: center; }
  .footer-content > *:nth-child(4) {
    display: flex;
    justify-content: center;
    padding-top: 20px;
  }
}

/* 8. Utilities bottom bar */
[data-testid="footer-utilities"] {
  font-size: 0.75rem !important;
}
</style>
